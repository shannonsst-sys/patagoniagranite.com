---
import BaseLayout from '@components/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import InquiryBand from '@components/InquiryBand.astro';
import { factorySteps } from '@data/galleries';
---
<BaseLayout title="Stone Factory & Fabrication" description="See TM Stone's Patagonia Granite sourcing, slab selection, cutting, polishing, CNC fabrication, dry layout, inspection, packing and export support.">
  <section class="page-hero"><img src="/assets/images/factory/patagonia-granite-factory-slab-aisle-01.webp" alt="Patagonia Granite slab aisle at TM Stone factory" /><div class="page-hero-content"><div><p class="eyebrow">Shuitou processing · worldwide support</p><h1>From Brazilian blocks to finished projects.</h1><p>One practical supply path for slab selection, surface finishing, cut-to-size work, layout, inspection and export packing.</p></div></div></section>
  <section class="section container"><SectionHeading eyebrow="Factory capability" title="Trust is built in the process." copy="TM Stone combines Brazilian block sourcing with a Shuitou processing base, showroom and finished-product workshop." /><div class="factory-list">{factorySteps.map((step,index)=><article class:list={['factory-row',index%2===1&&'reverse']}><div class="factory-image"><img src={step.image} alt={`${step.title} for natural stone projects`} loading="lazy" /></div><div><span>{String(index+1).padStart(2,'0')}</span><h2>{step.title}</h2><p>{step.description}</p></div></article>)}</div></section>
  <section class="equipment"><div class="container"><SectionHeading eyebrow="Equipment & output" title="Built for slabs and finished work." /><div class="equipment-grid">{[['Block cutting','Multi-wire saws, gang saws and block saws'],['Slab processing','Polishing lines and controlled surface finishing'],['Precision fabrication','Five-axis CNC, infrared bridge saws and waterjet'],['Custom elements','Cutouts, mitres, curves, inlays and architectural parts'],['Quality control','Dimensions, surface, edge, layout and packing checks'],['Export support','Wooden cases, container planning and documents']].map((item)=><div><h3>{item[0]}</h3><p>{item[1]}</p></div>)}</div></div></section>
  <InquiryBand title="Need slab supply or finished stone fabrication?" />
</BaseLayout>
<style>.factory-row{display:grid;grid-template-columns:1.3fr .7fr;gap:clamp(2rem,6vw,7rem);align-items:center;margin-bottom:clamp(5rem,9vw,10rem)}.factory-row.reverse{grid-template-columns:.7fr 1.3fr}.factory-row.reverse .factory-image{order:2}.factory-image{height:64vh;max-height:720px;min-height:430px;overflow:hidden}.factory-image img{width:100%;height:100%;object-fit:cover}.factory-row span{color:var(--bronze);font-size:.75rem}.factory-row h2{font-size:clamp(2.5rem,5vw,5rem);margin:1rem 0}.factory-row p{color:var(--muted);max-width:520px}.equipment{background:#dcd5ca;padding:clamp(5rem,9vw,9rem) 0}.equipment-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--line);border-left:1px solid var(--line)}.equipment-grid>div{padding:2rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}.equipment-grid p{color:var(--muted);margin-top:.8rem}@media(max-width:900px){.factory-row,.factory-row.reverse{grid-template-columns:1fr}.factory-row.reverse .factory-image{order:0}.equipment-grid{grid-template-columns:1fr 1fr}}@media(max-width:600px){.equipment-grid{grid-template-columns:1fr}}</style>
