---
import BaseLayout from '@components/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import InquiryBand from '@components/InquiryBand.astro';
---
<BaseLayout title="About TM Stone" description="TM Stone is a Shuitou-based natural stone supplier and manufacturer providing Brazilian block sourcing, slab processing and custom fabrication.">
  <section class="page-hero"><img src="/assets/images/factory/patagonia-granite-factory-slab-warehouse-01.webp" alt="TM Stone Patagonia Granite slab warehouse" /><div class="page-hero-content"><div><p class="eyebrow">TM Stone</p><h1>Natural stone, carried through the whole project.</h1><p>Brazilian block sourcing, Shuitou processing, finished-product fabrication and export support for international stone projects.</p></div></div></section>
  <section class="section container split"><div class="split-copy"><p class="eyebrow">Our company</p><h2>From blocks to finished stonework.</h2><p>TM Stone is a natural stone supplier and manufacturer based in Fushan Industrial Zone, Shuitou Town, Nan'an, Fujian, China. We source selected Brazilian natural stone blocks and process slabs and finished products for residential and commercial projects.</p><p>Our team supports importers, wholesalers, designers, contractors, cabinet companies, countertop fabricators and project clients with material selection, cutting, surface finishing, CNC work, dry layout, inspection, packing and shipment.</p></div><div class="split-media"><img src="/assets/images/factory/patagonia-granite-factory-slab-display-03.webp" alt="Patagonia Granite slabs selected at TM Stone showroom" /></div></section>
  <section class="section container"><SectionHeading eyebrow="Core advantages" title="Real material. Real processing. Clear support." /><div class="card-grid">{[['Selected block sourcing','Access distinctive Brazilian natural stone with stronger control from the material source.'],['Own Shuitou processing base','Slab cutting, surface finishing, cut-to-size and custom fabrication in one practical workflow.'],['Project-ready support','Layout planning, drawing coordination, inspection, wooden-crate packing and export shipment.']].map((item)=><div class="visual-card"><div class="body"><h3>{item[0]}</h3><p>{item[1]}</p></div></div>)}</div></section>
  <InquiryBand title="Work directly with the TM Stone team" />
</BaseLayout>
